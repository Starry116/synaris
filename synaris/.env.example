# ══════════════════════════════════════════════════════════════════════════════
# Synaris
# .env.example — 环境变量配置模板
#
# 使用方法：
#   cp .env.example .env
#   然后填写所有标记 [必填] 的变量
#
# 安全规则：
#   - .env 已在 .gitignore 中，永远不要提交到 Git
#   - 生产环境建议通过 CI/CD Secret 或 Vault 注入，而不是直接使用 .env 文件
# ══════════════════════════════════════════════════════════════════════════════


# ── App 基础配置 ──────────────────────────────────────────────────────────────

APP_NAME=Synaris
APP_VERSION=1.0.0
API_PREFIX=/api/v1
DEBUG=false

# 运行环境：development | staging | production
ENVIRONMENT=production

# 速率限制（slowapi 格式）
RATE_LIMIT=60/minute

# 允许跨域的前端地址，多个用英文逗号分隔，不要有空格
CORS_ORIGINS=http://localhost:3000,http://localhost:8080


# ── OpenAI 配置 ───────────────────────────────────────────────────────────────

# [必填] 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-key-here

# 如果使用代理或 Azure OpenAI，修改此地址；否则保持默认
OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# 模型路由三档：
#   QUALITY  → 复杂推理任务（Agent、分析报告）
#   DEFAULT  → 日常对话（BALANCED 策略，成本与质量平衡）
#   ECONOMY  → 简单任务（批量处理、摘要）
#   FALLBACK → 主模型故障时的兜底，必须比 DEFAULT 更便宜
QUALITY_MODEL=gpt-4o
DEFAULT_MODEL=gpt-4o-mini
ECONOMY_MODEL=gpt-3.5-turbo
FALLBACK_MODEL=gpt-3.5-turbo

# Embedding 配置（维度必须与 Milvus Collection Schema 一致，不可随意修改）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# ── Milvus 向量数据库 ─────────────────────────────────────────────────────────

# Docker 环境使用服务名 milvus；本地开发直接运行时改为 localhost
MILVUS_HOST=milvus
MILVUS_PORT=19530

MILVUS_COLLECTION_NAME=synaris_knowledge
MILVUS_MEMORY_COLLECTION=synaris_long_term_memory

# HNSW 索引参数（修改后需重建索引才生效）
# M：图连接数，越大召回率越高，内存越多，建议范围 8-64
# EF_CONSTRUCTION：构建质量，越大越精准但越慢，建议范围 128-512
# SEARCH_EF：查询探索深度，越大召回率越高但延迟越高，建议范围 32-128
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=256
MILVUS_SEARCH_EF=64

MILVUS_DEFAULT_TOP_K=5

# 余弦相似度阈值 [0.0, 1.0]，低于此值的检索结果直接丢弃
MILVUS_SIMILARITY_THRESHOLD=0.70


# ── Redis 缓存 ────────────────────────────────────────────────────────────────

# 主缓存（db=0）：存储 Embedding、检索结果、聊天历史
# Docker 环境用服务名 redis；本地开发改为 localhost
REDIS_URL=redis://redis:6379/0

# Celery Broker（db=1）：与缓存数据隔离，防止 flush 时互相影响
REDIS_CELERY_URL=redis://redis:6379/1

REDIS_MAX_CONNECTIONS=20

# TTL 单位均为秒（代码中用乘法表达，此处直接填数字）
CACHE_TTL_SHORT=600       # 10 分钟 — 检索结果缓存
CACHE_TTL_LONG=86400      # 24 小时 — Embedding 缓存
CACHE_TTL_SESSION=7200    #  2 小时 — 聊天历史缓存
CACHE_TTL_TASK=3600       #  1 小时 — 任务上下文缓存

# 单个会话在 Redis 中保留的最大消息条数，超出后滑动丢弃最早的消息
CHAT_HISTORY_MAX_MESSAGES=20


# ── PostgreSQL 结构化数据库 ───────────────────────────────────────────────────

# asyncpg 连接串格式：postgresql+asyncpg://用户名:密码@主机:端口/数据库名
# Docker 环境主机用服务名 postgres；本地开发改为 localhost
POSTGRES_URL=postgresql+asyncpg://synaris:synaris_pass@postgres:5432/synaris

POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30

# 是否打印所有 SQL 语句，生产环境必须为 false
POSTGRES_ECHO=false


# ── 日志配置 ──────────────────────────────────────────────────────────────────

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式：
#   json → 生产环境 / ELK Filebeat 采集（结构化，机器可读）
#   text → 本地开发（带颜色，人类可读）
LOG_FORMAT=json

# 用于 ELK / Prometheus 多服务区分
LOG_SERVICE_NAME=synaris

# 日志中记录的环境标识：development | staging | production
LOG_ENVIRONMENT=production


# ── 安全认证 ──────────────────────────────────────────────────────────────────

# [必填] JWT 签名密钥，长度至少 32 字符
# 生成命令：openssl rand -hex 32
SECRET_KEY=your-secret-key-replace-this-immediately

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# API Key 认证时使用的 HTTP Header 名称
API_KEY_HEADER_NAME=X-API-Key


# ── Celery 任务队列 ───────────────────────────────────────────────────────────

# Worker 并发进程数，建议设置为 CPU 核心数 × 2（IO密集型任务）
CELERY_WORKER_CONCURRENCY=4

# 任务失败重试次数
CELERY_TASK_MAX_RETRIES=3

# 指数退避基础间隔（秒）
# 第1次重试: 60s, 第2次: 120s, 第3次: 240s
CELERY_TASK_RETRY_BACKOFF=60

# 三优先级队列名称（一般不需要修改）
QUEUE_HIGH=high_priority
QUEUE_DEFAULT=default
QUEUE_LOW=low_priority


# ── RAG 文档处理参数 ──────────────────────────────────────────────────────────

# 文档分块大小（字符数），影响检索精度和 Prompt 长度
CHUNK_SIZE=512

# 相邻分块重叠字符数，防止关键语义在块边界处被截断
CHUNK_OVERLAP=50

# Reranking 后注入 Prompt 的文档数量，越多上下文越丰富但 Token 消耗越高
RAG_RERANK_TOP_K=3


# ── 成本监控 ──────────────────────────────────────────────────────────────────

# 日费用告警阈值（美元），超出后写入 WARNING 级别日志
# 可扩展为邮件 / Slack 通知
COST_ALERT_DAILY_USD=50.0
