# ══════════════════════════════════════════════════════════════════════════════
# Synaris — .env.example 配置文件
#
# 使用方法：
#   cp .env.example .env
#   然后填写所有标记 [必填] 的变量
#
# 安全规则：
#   - .env 已在 .gitignore 中，永远不要提交到 Git
#   - 生产环境通过 CI/CD Secret 或 Vault 注入，不要直接使用 .env 文件
# ══════════════════════════════════════════════════════════════════════════════


# ── App 基础配置 ──────────────────────────────────────────────────────────────

APP_NAME=Synaris
APP_VERSION=3.0.0
API_PREFIX=/api/v1
DEBUG=false

# 运行环境：development | staging | production
ENVIRONMENT=production

# 速率限制（slowapi 格式）
RATE_LIMIT=60/minute

# 允许跨域的前端地址（多个用英文逗号分隔，不要有空格）
CORS_ORIGINS=http://localhost:3000,http://localhost:8080


# ── OpenAI 配置 ───────────────────────────────────────────────────────────────

# [必填] 从 https://platform.openai.com/api-keys 获取
OPENAI_API_KEY=sk-your-key-here

# 如果使用代理或 Azure OpenAI，修改此地址；否则保持默认
OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_TIMEOUT=60
OPENAI_MAX_RETRIES=3

# 模型路由三档：
#   QUALITY_MODEL  → 复杂推理（Agent 规划、分析报告）
#   DEFAULT_MODEL  → 日常对话（成本与质量均衡）
#   ECONOMY_MODEL  → 简单批量任务
#   FALLBACK_MODEL → 主模型故障时的兜底（必须 ≤ DEFAULT 成本）
QUALITY_MODEL=gpt-4o
DEFAULT_MODEL=gpt-4o-mini
ECONOMY_MODEL=gpt-3.5-turbo
FALLBACK_MODEL=gpt-3.5-turbo

# Embedding（维度必须与 Milvus Collection Schema 一致，修改后需重建 Collection）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536


# ── Milvus 向量数据库 ─────────────────────────────────────────────────────────

# Docker 环境使用服务名 milvus；本地直接运行改为 localhost
MILVUS_HOST=milvus
MILVUS_PORT=19530

MILVUS_COLLECTION_NAME=synaris_knowledge
MILVUS_MEMORY_COLLECTION=synaris_long_term_memory

# HNSW 索引参数（修改后需重建索引才生效）
MILVUS_HNSW_M=16
MILVUS_HNSW_EF_CONSTRUCTION=256
MILVUS_SEARCH_EF=64

MILVUS_DEFAULT_TOP_K=5
MILVUS_SIMILARITY_THRESHOLD=0.70


# ── Redis 缓存 ────────────────────────────────────────────────────────────────

# DB 0 = 业务缓存（Embedding / 检索结果 / 聊天历史）
REDIS_URL=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# TTL 单位：秒
CACHE_TTL_SHORT=600       # 10 分钟 — 检索结果缓存
CACHE_TTL_LONG=86400      # 24 小时 — Embedding 缓存
CACHE_TTL_SESSION=7200    #  2 小时 — 聊天历史缓存
CACHE_TTL_TASK=3600       #  1 小时 — 任务上下文缓存

# 单会话最大历史消息条数（超出后滑动丢弃）
CHAT_HISTORY_MAX_MESSAGES=20


# ── PostgreSQL 结构化数据库 ───────────────────────────────────────────────────
# [Step 21 新增]

# [必填] asyncpg 连接串
# Docker 环境主机用服务名 postgres；本地开发改为 localhost
POSTGRES_URL=postgresql+asyncpg://synaris:synaris_dev@postgres:5432/synaris

# 单独字段（init_db.sh 等脚本使用）
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=synaris
POSTGRES_USER=synaris
# [必填] 设置一个强密码
POSTGRES_PASSWORD=synaris_dev

POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30

# 是否打印 SQL，生产环境必须为 false
POSTGRES_ECHO=false


# ── 日志配置 ──────────────────────────────────────────────────────────────────

# 日志级别：DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# 日志格式：json（生产/ELK）| text（开发，带颜色）
LOG_FORMAT=json

LOG_SERVICE_NAME=synaris
LOG_ENVIRONMENT=production


# ── 安全认证 ──────────────────────────────────────────────────────────────────

# [必填] JWT 签名密钥，至少 32 字符
# 生成命令：openssl rand -hex 32
SECRET_KEY=your-secret-key-replace-this-immediately

JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=24

# 密钥轮转（更换 SECRET_KEY 时，将旧值移到此处，保留 24h 过渡期）
SECRET_KEY_PREVIOUS=

# API Key 认证 Header 名称
API_KEY_HEADER_NAME=X-API-Key


# ── Celery 任务队列 ───────────────────────────────────────────────────────────
# [Step 20/26 新增]

# DB 1 = Celery Broker（与缓存 DB 0 物理隔离）
CELERY_BROKER_URL=redis://redis:6379/1

# DB 2 = Celery Result Backend
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Worker 并发进程数（建议 CPU 核心数 × 2，IO 密集型任务）
CELERY_WORKER_CONCURRENCY=4

# 任务失败最大重试次数
CELERY_TASK_MAX_RETRIES=3

# 指数退避基础间隔（秒）：第1次=60s，第2次=120s，第3次=240s
CELERY_TASK_RETRY_BACKOFF=60

# Celery Flower 监控仪表盘认证
FLOWER_USER=admin
FLOWER_PASSWORD=admin


# ── MinIO 对象存储 ────────────────────────────────────────────────────────────
# [Step 26 新增 ROOT_USER / ROOT_PASSWORD 变量]

# MinIO 管理员账号（必须一致，Milvus 与 app 都使用这组凭证）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# MinIO API 地址（docker-compose 内部通信）
MINIO_ENDPOINT=minio:9000

# app 使用的存储桶名（init_db.sh 会自动创建）
MINIO_BUCKET=synaris-docs


# ── RAG 文档处理参数 ──────────────────────────────────────────────────────────

CHUNK_SIZE=512
CHUNK_OVERLAP=50
RAG_RERANK_TOP_K=3


# ── 成本监控 ──────────────────────────────────────────────────────────────────

# 日费用告警阈值（美元），超出后写 WARNING 级别日志
COST_ALERT_DAILY_USD=50.0


# ── 监控仪表盘 ────────────────────────────────────────────────────────────────

# Grafana 管理员账号
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# 生产环境额外变量（docker-compose.prod.yml 使用）
# GRAFANA_SECRET_KEY=your-grafana-secret-key
# DOMAIN=your-domain.com
# REDIS_PASSWORD=your-redis-password

# ── 管理员初始账号（init_db.sh 首次运行时创建）──────────────────────────────

ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@synaris.local
ADMIN_PASSWORD=synaris520

# ── 可选：外部搜索工具 ────────────────────────────────────────────────────────

# Tavily 搜索 API（比 DuckDuckGo 质量更高，Agent web_search 工具首选）
# 申请地址：https://tavily.com
TAVILY_API_KEY=
